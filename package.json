{
  "name": "weixin-miniprogram-cli",
  "version": "1.0.0",
  "description": "微信开发者工具交互式 CLI 控制器",
  "type": "module",
  "main": "build/cli.js",
  "types": "build/cli.d.ts",
  "bin": {
    "wx-mp-cli": "./build/cli.js"
  },
  "files": [
    "build/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x build/cli.js build/daemon.js",
    "clean": "rm -rf build",
    "prebuild": "rm -rf build",
    "watch": "tsc --watch",
    "start": "node build/cli.js",
    "dev": "npx tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wechat",
    "miniprogram",
    "devtools",
    "cli",
    "automation",
    "testing",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BigLiao/weixin-miniprogram-cli.git"
  },
  "homepage": "https://github.com/BigLiao/weixin-miniprogram-cli#readme",
  "bugs": {
    "url": "https://github.com/BigLiao/weixin-miniprogram-cli/issues"
  },
  "author": "LiaoZhibin",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "minimist": "^1.2.8",
    "miniprogram-automator": "^0.12.1"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.0.0",
    "miniprogram-ci": "^2.1.31",
    "typescript": "^5.4.0"
  }
}
