{
  "name": "wx-mp-cli",
  "version": "0.1.0",
  "description": "微信开发者工具交互式 CLI 控制器",
  "type": "module",
  "main": "build/cli.js",
  "bin": {
    "wx-mp-cli": "./build/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x build/cli.js build/daemon.js",
    "watch": "tsc --watch",
    "start": "node build/cli.js",
    "dev": "npx tsx src/cli.ts",
    "setup": "node examples/setup.mjs",
    "launch": "node examples/launch.mjs",
    "launch:skip-login": "node examples/launch.mjs --skip-login",
    "test:all": "node examples/test-scripts/run-all.mjs",
    "test:connection": "node examples/test-scripts/test-connection.mjs",
    "test:page": "node examples/test-scripts/test-page.mjs",
    "test:input": "node examples/test-scripts/test-input.mjs",
    "test:navigate": "node examples/test-scripts/test-navigate.mjs",
    "test:assert": "node examples/test-scripts/test-assert.mjs",
    "test:console": "node examples/test-scripts/test-console.mjs",
    "test:network": "node examples/test-scripts/test-network.mjs",
    "test:screenshot": "node examples/test-scripts/test-screenshot-script.mjs",
    "test:diagnose": "node examples/test-scripts/test-diagnose.mjs",
    "test:launch": "node examples/test-scripts/test-launch.mjs",
    "test:launch:skip-login": "node examples/test-scripts/test-launch.mjs --skip-login"
  },
  "keywords": [
    "wechat",
    "miniprogram",
    "devtools",
    "cli",
    "automation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "minimist": "^1.2.8",
    "miniprogram-automator": "^0.12.1"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.0.0",
    "miniprogram-ci": "^2.1.31",
    "typescript": "^5.4.0"
  }
}
